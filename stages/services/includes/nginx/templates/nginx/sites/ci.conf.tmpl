server {
  listen 80;
  listen [::]:80;
  server_name {{ .nginx.sites.ci.server_name }};

  include /etc/nginx/common_ratelimit.conf;

  return 301 https://\$server_name\$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    access_log /var/log/nginx/{{ .nginx.sites.ci.server_name }}_access.log json;
    error_log /var/log/nginx/{{ .nginx.sites.ci.server_name }}_error.log;

    ### SSL cert files ###
    ssl_certificate {{ .nginx.variables.new_ssl_certificate }};
    ssl_certificate_key {{ .nginx.variables.new_ssl_certificate_key }};

    ### Add SSL specific settings here ###
    ssl_session_timeout 10m;

    ssl_protocols TLSv1 TLSv1.1 TLSv1.2;
    ssl_ciphers '{{ .nginx.variables.ssl_ciphers }}';
    ssl_prefer_server_ciphers on;

    ### Compression
    gzip on;
    gzip_comp_level    5;
    gzip_min_length    256;
    gzip_proxied       any;
    gzip_vary          on;
    gzip_types
    application/rss+xml
    text/css;

    server_name {{ .nginx.sites.ci.server_name }};

    location / {
        proxy_set_header   X-Forwarded-For \$remote_addr;
        proxy_set_header   X-Forwarded-Proto \$scheme;
        proxy_set_header   Host \$http_host;

        proxy_pass http://{{ .nginx.sites.ci.upstream }};
        proxy_redirect     off;
        proxy_http_version 1.1;
        proxy_buffering    off;

        chunked_transfer_encoding off;
    }
}
