server {
  listen 80;
  listen [::]:80;
  server_name vpn.tiredsysadmin.cc;

  include /etc/nginx/common_ratelimit.conf;

  return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    access_log /var/log/nginx/vpn.tiredsysadmin.cc_access.log json;
    error_log /var/log/nginx/vpn.tiredsysadmin.cc_error.log;

    ### SSL cert files ###
    ssl_certificate {{ .nginx.variables.blog_ssl_certificate }};
    ssl_certificate_key {{ .nginx.variables.blog_ssl_certificate_key }};

    ### Add SSL specific settings here ###
    ssl_session_timeout 10m;

    ssl_protocols TLSv1 TLSv1.1 TLSv1.2;
    ssl_ciphers '{{ .nginx.variables.ssl_ciphers }}';
    ssl_prefer_server_ciphers on;

    server_name vpn.tiredsysadmin.cc;

    client_max_body_size 200M;

    location / {
        proxy_pass http://10.200.1.2:51821;
    }
}
