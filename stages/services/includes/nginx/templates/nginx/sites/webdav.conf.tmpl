server {
    listen 80;
    listen [::]:80;
    server_name {{ .nginx.sites.webdav.server_name }};

    include /etc/nginx/common_ratelimit.conf;

    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;

    access_log /var/log/nginx/{{ .nginx.sites.webdav.server_name }}_access.log json;
    error_log /var/log/nginx/{{ .nginx.sites.webdav.server_name }}_error.log;

    ### SSL cert files ###
    ssl_certificate {{ .nginx.variables.new_ssl_certificate }};
    ssl_certificate_key {{ .nginx.variables.new_ssl_certificate_key }};

    ### Add SSL specific settings here ###
    ssl_session_timeout 10m;

    ssl_protocols TLSv1 TLSv1.1 TLSv1.2;
    ssl_ciphers '${ssl_ciphers}';
    ssl_prefer_server_ciphers on;

    server_name {{ .nginx.sites.webdav.server_name }};

    include /etc/nginx/common_ratelimit.conf;

    location / {
        auth_basic "Protected area";
        auth_basic_user_file /etc/nginx/htpasswd;
        client_max_body_size 0;
        proxy_pass http://10.200.1.3:38000; 
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    } 
}
