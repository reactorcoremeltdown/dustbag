server {
    listen 80;
    listen [::]:80;
    server_name {{ .nginx.sites.dav.server_name }};

    include /etc/nginx/common_ratelimit.conf;

    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    access_log /var/log/nginx/{{ .nginx.sites.dav.server_name }}_access.log json;
    error_log /var/log/nginx/{{ .nginx.sites.dav.server_name }}_error.log;

    ### SSL cert files ###
    ssl_certificate {{ .nginx.variables.new_ssl_certificate }};
    ssl_certificate_key {{ .nginx.variables.new_ssl_certificate_key }};

    ### Add SSL specific settings here ###
    ssl_session_timeout 10m;

    ssl_protocols TLSv1 TLSv1.1 TLSv1.2;
    ssl_ciphers '{{ .nginx.variables.ssl_ciphers }}';
    ssl_prefer_server_ciphers on;

    server_name {{ .nginx.sites.dav.server_name }};

    include /etc/nginx/common_ratelimit.conf;

    location / {
        return 200 "It works!";
    }

    location /radicale/ {
        mirror /ingest;
        proxy_read_timeout 300;
        proxy_pass        http://{{ .nginx.sites.dav.upstream }}/; # The / is important!
        proxy_set_header  X-Script-Name /radicale;
        proxy_set_header  X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_pass_header Authorization;
    }
    location /ingest {
        internal;
        proxy_read_timeout 300;
        proxy_pass        http://{{ .nginx.sites.dav.upstream_ingest_route }}/ingest$request_uri; # The / is important!
        proxy_set_header  X-Script-Name /radicale;
        proxy_set_header  X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_pass_header Authorization;
    }
}
